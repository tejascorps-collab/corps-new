# Copy to .env and fill in. On the VPS this lives outside git.
DATABASE_URL="file:./data/fdi.db"
PORT=4100

# Secret used to sign JWT access tokens. Generate with: openssl rand -hex 32
JWT_SECRET="change-me-generate-a-long-random-secret"

# Comma-separated allowed origins for CORS (dev + prod).
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:4173,https://app.akontec.pro"

# Seeded login accounts. Passwords are applied on every `npm run seed`, so a
# manual re-seed rotates them to whatever is set here. Use strong values.
SEED_SUPERADMIN_EMAIL="superadmin@akontec.pro"
SEED_SUPERADMIN_PASSWORD="change-me-strong-super-admin-password"
SEED_ADMIN_PASSWORD="change-me-strong-admin-password"
SEED_TEAM_PASSWORD="change-me-strong-team-password"
